<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bp.jaringochi.domain.category.dao.CategoryDao">

    <!-- 1. 추가
         - id / created_at / updated_at 은 DB가 자동 생성 -> INSERT에서 제외
         - is_active 는 schema의 DEFAULT 1 사용 -> 제외 (새 카테고리는 기본이 '사용')
         - display_order 는 자동관리 안 함(옵션 X) -> 제외, DB DEFAULT 0 사용 -> 추후 구현
         - useGeneratedKeys + keyProperty: 생성된 PK를 category.id 에 다시 채워줌
           (응답으로 '생성된 카테고리'를 돌려주려면 새 id가 필요하기 때문) -->
    <insert id="insertCategory" parameterType="Category"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO category (user_id, name, type, icon, color)
        VALUES (#{userId}, #{name}, #{type}, #{icon}, #{color})
    </insert>

    <!-- 2. 목록 조회
         - 기본 제공 카테고리(user_id IS NULL) + 사용자가 추가한 카테고리(user_id = #{userId})
         - is_active = 1 (숨김 처리된 것 제외)
         - 정렬: 수입/지출(type) 묶고, 그 안에서 생성순(id) -> 새로 추가한 카테고리는 맨 뒤로 정렬됨 -->
    <select id="selectCategories" resultType="Category">
        SELECT id, user_id, name, type, display_order, is_active, icon, color, created_at, updated_at
        FROM category
        WHERE (user_id = #{userId} OR user_id IS NULL)
          AND is_active = 1
          AND type = #{type}
        ORDER BY type, id
    </select>

    <!-- 3. 단건 조회 (수정/삭제 전 존재·소유 확인용)
         WHERE id = #{id}
         - id 로만 조회
         - 해당 유저인지는(user_id) Service에서 소유권 판단 -->
    <select id="selectCategoryById" resultType="Category">
        SELECT id, user_id, name, type, display_order, is_active, icon, color, created_at, updated_at
        FROM category
        WHERE id = #{id}
    </select>

    <!-- 4. 수정
    	WHERE id = #{id}
         - 소유권 검증은 Service에서 (selectCategoryById 로 먼저 확인)
         
         - display_order 는 추후에
         - updated_at 은 ON UPDATE CURRENT_TIMESTAMP 로 DB가 자동 갱신 → SET에서 제외 -->
    <update id="updateCategory" parameterType="Category">
        UPDATE category
        SET name = #{name},
            type = #{type},
            icon = #{icon},
            color = #{color}
        WHERE id = #{id}
    </update>

    <!-- 5. 삭제 = 소프트 삭제 (실제 DELETE 아님)
         - is_active = 0 으로만 변경 -> 과거 거래내역 보존 -->
    <update id="hideCategory">
        UPDATE category
        SET is_active = 0
        WHERE id = #{id}
    </update>

</mapper>